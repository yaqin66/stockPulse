# ==============================================================================
# NGINX Configuration Template untuk StockPulse
# ==============================================================================
# 1. Copy file ini ke /etc/nginx/sites-available/stockpulse
# 2. Sesuaikan `server_name` dan `root` dengan absolute path folder Anda.
# 3. Buat symlink: sudo ln -s /etc/nginx/sites-available/stockpulse /etc/nginx/sites-enabled/
# 4. Restart NGINX: sudo systemctl restart nginx
# ==============================================================================

server {
    listen 80;
    
    # Ganti dengan domain Anda atau IP Public VPS Anda
    server_name stockpulse.domainanda.com 103.xxx.xxx.xxx;

    # Ganti path ini ke lokasi aktual folder "dist" hasil npm run build Anda
    # Contoh: /home/ubuntu/stockpulse/dist;
    root /path/to/your/stockpulse/dist;
    
    index index.html index.htm;

    # 1. Serve frontend React (SPA routing)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 2. Proxy request /api ke server Express Puppeteer (Port 3001)
    location /api/ {
        proxy_pass http://127.0.0.1:3001/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        
        # Opsi: Perpanjang timeout karena Puppeteer terkadang butuh waktu lama
        proxy_read_timeout 60s;
        proxy_connect_timeout 60s;
    }

    # 3. Proxy request /api-yf ke server Express YFinance (Port 3002)
    location /api-yf/ {
        # Menghapus prefiks /api-yf agar masuk ke /api di server.js backend
        rewrite ^/api-yf/(.*) /api/$1 break;
        
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
}
