# StockPulse Python Scraper — Environment Variables
# Salin file ini ke .env lalu isi nilai yang sesuai

# ─── PostgreSQL ───────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=stockpulse
PG_USER=postgres
PG_PASSWORD=your_password_here

# ─── Scraper ─────────────────────────────────────────────────
# Delay antar request ke IDX (detik) — jangan terlalu kecil!
SCRAPE_DELAY=1.5
# Timeout per request (detik)
SCRAPE_TIMEOUT=30

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=scraper.log
